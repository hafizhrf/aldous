---
---

<div
	class="p-4 bg-white block border-b border-gray-200 lg:mt-1.5 dark:bg-gray-800 dark:border-gray-700"
>
	<div class="mb-4">
		<div class="flex items-center justify-between">
			<h1
				class="text-xl font-semibold text-gray-900 sm:text-2xl dark:text-white"
			>
				Issues by Copilot
			</h1>
			<a
				href="https://github.com/search?q=org%3Amataharibiz+assignee%3A%40copilot&type=issues&p=2"
				target="_blank"
				rel="noopener noreferrer"
				class="text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
				title="View on GitHub"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
					></path>
				</svg>
			</a>
		</div>
		<p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Total 19 issues</p>
	</div>
</div>

<div class="p-4">
	<div class="grid grid-cols-1 gap-4 md:grid-cols-3">
		<div
			class="block p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700"
		>
			<div class="flex items-start justify-between mb-2">
				<h5
					class="text-lg font-semibold tracking-tight text-gray-900 dark:text-white"
				>
					Open
				</h5>
				<span
					class="ml-2 bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-green-900 dark:text-green-300"
				>
					Open
				</span>
			</div>
			<span
				class="text-2xl font-bold leading-none text-gray-900 sm:text-3xl dark:text-white"
			>
				15
			</span>
		</div>

		<div
			class="block p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700"
		>
			<div class="flex items-start justify-between mb-2">
				<h5
					class="text-lg font-semibold tracking-tight text-gray-900 dark:text-white"
				>
					Closed
				</h5>
				<span
					class="ml-2 bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-red-900 dark:text-red-300"
				>
					Closed
				</span>
			</div>
			<span
				class="text-2xl font-bold leading-none text-gray-900 sm:text-3xl dark:text-white"
			>
				4
			</span>
		</div>

		<div
			class="block p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700"
		>
			<div class="flex items-start justify-between mb-2">
				<h5
					class="text-lg font-semibold tracking-tight text-gray-900 dark:text-white"
				>
					Total
				</h5>
				<span
					class="ml-2 bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-blue-900 dark:text-blue-300"
				>
					All
				</span>
			</div>
			<span
				class="text-2xl font-bold leading-none text-gray-900 sm:text-3xl dark:text-white"
			>
				19
			</span>
		</div>
	</div>
</div>
