---
import githubLogo from '../assets/github.png';

let issues = {
	open: 0,
	closed: 0,
	total: 0,
	github_url:
		'https://github.com/search?q=org%3Amataharibiz+assignee%3A%40copilot&type=issues',
};

try {
	const res = await fetch(
		`${import.meta.env.PUBLIC_API_BASE_URL}/issues/copilot`,
	);
	if (res.ok) {
		issues = await res.json();
	}
} catch (e) {
	console.error('Failed to fetch copilot issues:', e);
}

const { open, closed, total, github_url } = issues;

const getGithubUrlWithState = (url, state) => {
	try {
		const urlObj = new URL(url);
		urlObj.searchParams.delete('p');
		if (state) {
			const currentQ = urlObj.searchParams.get('q') || '';
			urlObj.searchParams.set('q', `${currentQ} is:${state}`);
		}
		return urlObj.toString();
	} catch (e) {
		return url;
	}
};

const openUrl = getGithubUrlWithState(github_url, 'open');
const closedUrl = getGithubUrlWithState(github_url, 'closed');
const totalUrl = getGithubUrlWithState(github_url, null);
---

<div
	class="p-4 bg-white block border-b border-gray-200 lg:mt-1.5 dark:bg-gray-800 dark:border-gray-700"
>
	<div class="mb-4">
		<div class="flex items-center justify-between">
			<h1
				class="text-xl font-semibold text-gray-900 sm:text-2xl dark:text-white flex items-center"
			>
				<img
					src={githubLogo}
					alt="GitHub"
					class="w-6 h-6 mr-2 object-contain dark:invert"
				/>
				Copilot Assisted Issues
			</h1>
			<a
				href={totalUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
				title="View on GitHub"
			>
				<svg
					class="w-5 h-5"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
					></path>
				</svg>
			</a>
		</div>
		<p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
			Total {total} issues
		</p>
	</div>
</div>

<div class="p-4">
	<div class="grid grid-cols-1 gap-4 md:grid-cols-3">
		<a
			href={openUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="block p-6 bg-white border border-gray-200 rounded-lg shadow hover:bg-gray-50 dark:bg-gray-800 dark:border-gray-700 dark:hover:bg-gray-700 transition-colors"
		>
			<div class="flex items-start justify-between mb-2">
				<h5
					class="text-lg font-semibold tracking-tight text-gray-900 dark:text-white"
				>
					Open
				</h5>
				<span
					class="ml-2 bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-green-900 dark:text-green-300"
				>
					Open
				</span>
			</div>
			<span
				class="text-2xl font-bold leading-none text-gray-900 sm:text-3xl dark:text-white"
			>
				{open}
			</span>
		</a>

		<a
			href={closedUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="block p-6 bg-white border border-gray-200 rounded-lg shadow hover:bg-gray-50 dark:bg-gray-800 dark:border-gray-700 dark:hover:bg-gray-700 transition-colors"
		>
			<div class="flex items-start justify-between mb-2">
				<h5
					class="text-lg font-semibold tracking-tight text-gray-900 dark:text-white"
				>
					Closed
				</h5>
				<span
					class="ml-2 bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-red-900 dark:text-red-300"
				>
					Closed
				</span>
			</div>
			<span
				class="text-2xl font-bold leading-none text-gray-900 sm:text-3xl dark:text-white"
			>
				{closed}
			</span>
		</a>

		<a
			href={totalUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="block p-6 bg-white border border-gray-200 rounded-lg shadow hover:bg-gray-50 dark:bg-gray-800 dark:border-gray-700 dark:hover:bg-gray-700 transition-colors"
		>
			<div class="flex items-start justify-between mb-2">
				<h5
					class="text-lg font-semibold tracking-tight text-gray-900 dark:text-white"
				>
					Total
				</h5>
				<span
					class="ml-2 bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-blue-900 dark:text-blue-300"
				>
					All
				</span>
			</div>
			<span
				class="text-2xl font-bold leading-none text-gray-900 sm:text-3xl dark:text-white"
			>
				{total}
			</span>
		</a>
	</div>
</div>
